          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="i_assumptions" parent="1" style="text;html=1;fontSize=11;fontColor=#232F3E;align=left;verticalAlign=top;whiteSpace=wrap;" value="Assumptions:&#xa;• Ingestion is a scheduled OUTBOUND pull from data.gov.sg&#39;s public API — no inbound listener/port is exposed by HDB, since data.gov.sg never initiates a connection to HDB.&#xa;• data.gov.sg API has been observed to rate-limit after ~3 consecutive calls; poll-and-retry logic (max_attempts/poll_interval) in the existing pipeline handles this, favoring Fargate (no execution time ceiling) over Lambda.&#xa;• Existing Polars pipeline (0_data_unification.py → 3_transformation.py) is deployed as-is in a Docker container on Fargate, not reimplemented in Glue, to avoid maintaining two parallel logic paths.&#xa;• Large file (&gt;100MB) transmission is handled natively by S3 multipart upload and streaming CSV read; no custom chunking required.&#xa;• SSE-S3 default encryption assumed on the bucket (not an explicit brief requirement, included as baseline security).&#xa;• Yellow/blue call-vs-data split applies only to true request-response hops; the Fargate→S3 write and the EventBridge/Step Functions trigger chain are single-direction by nature." vertex="1">
          <mxGeometry height="120" width="1140" x="250" y="800" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
