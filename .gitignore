# Ignore everything by default
*
# Allow traversal into these directories
# !/datalake/
# !/output/
!/scripts/
# !/venv/

# Allow everything inside them
# !/datalake/**
# !/output/**
!/scripts/**
/scripts/**/__pycache__/
/scripts/.DS_Store

# !/venv/**

# Allow these specific top-level files
!/requirements.txt
!/run_pipeline.sh
# !/setup_datalake.sh
!/setup.sh
!/dev_controltower.py
!/.gitignore
!/README.md

